# API Configuration
# Leave empty to use Vite dev server proxy (recommended for development)
# Set to http://localhost:8000 for direct backend access (may be affected by system proxy)
VITE_API_BASE_URL=
VITE_API_BASE_PATH=/api

# Application Configuration
VITE_APP_TITLE=EDF Viewer
VITE_APP_VERSION=2.0.0

# Feature Flags
VITE_ENABLE_OVERVIEW_STRIP=true
VITE_ENABLE_BOOKMARKS=true
VITE_ENABLE_KEYBOARD_SHORTCUTS=true
